# ============================================================
# InsureFlow CRM — .gitignore
# Next.js 14 | TypeScript | MongoDB | Tailwind CSS
# ============================================================

# ─── Dependencies ───────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Environment Variables (NEVER commit secrets) ───────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# ─── Next.js Build Output ───────────────────────────────────
.next/
out/
build/
dist/

# ─── Cache ──────────────────────────────────────────────────
.cache/
.turbo/
.swc/

# ─── Testing ────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Logs ───────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── OS / System Files ──────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Editor & IDE ───────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Package Manager Locks (keep only one) ──────────────────
# Uncomment the lock file your project does NOT use:
# package-lock.json   # if using yarn/pnpm
# yarn.lock           # if using npm/pnpm
# pnpm-lock.yaml      # if using npm/yarn

# ─── Scaffolding / One-off Scripts ──────────────────────────
scaffold_apis.js
scaffold_*.js
scaffold_*.ts

# ─── Uploads & User-generated Content ───────────────────────
public/uploads/
uploads/

# ─── Misc ───────────────────────────────────────────────────
*.pem
*.key
*.cert
*.p12
*.pfx
